						mesh.Scale=v3(0.6,0.6,(lasttrailpos-position).Magnitude*5)
						debris:AddItem(trail,0.5)
						lasttrailpos=position
						lasttrailt=time
					end
					flyingnade.CFrame=cf(position+offset)*cframe.fromaxisangle(t*av0)*rot0
				else
					explode()
					stop()
				end
			end
		end)
		return stop
		--arb
	end)

