		--fix shitty code

		local data				=require(game.ReplicatedStorage.GrenadeModules[grenade])
		local flyingnade		=game.ReplicatedStorage.GrenadeModels[grenade].Trigger:Clone()
		local ignorelist		={camera.currentcamera,char.character,workspace.Ignore}
		local lasttrailt		=0
		local lasttrailpos		=v3()
		local offset			=v3()
		local lastbounce
		local exploded	
		local blowup			=tick()+blowtime
		local indicator			=ffc(flyingnade,"Indicator")

		flyingnade.Parent=camera.currentcamera
